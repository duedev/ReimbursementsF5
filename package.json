{
  "name": "dueback",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Receipts in. Reimbursement report out. A browser-only receipt → spreadsheet app with on-device OCR, visual logo recognition, and optional Supabase sync.",
  "scripts": {
    "vendor": "node scripts/vendor-tesseract.mjs",
    "vendor:paddle": "node scripts/vendor-paddle.mjs",
    "predev": "npm run vendor",
    "dev": "vite",
    "prebuild": "npm run vendor",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && svelte-check --tsconfig ./tsconfig.json",
    "test": "node --import tsx --test tests/*.test.ts",
    "testkit": "node --import tsx --test tests/testkit/*.test.ts",
    "e2e": "node tests/e2e.mjs",
    "icons": "node scripts/gen-icons.mjs"
  },
  "dependencies": {
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/inter": "^5.2.8",
    "@huggingface/transformers": "^4.2.0",
    "@supabase/supabase-js": "^2.110.0",
    "chart.js": "^4.5.1",
    "exceljs": "^4.4.0",
    "idb": "^8.0.3",
    "pdfjs-dist": "^4.10.38",
    "tesseract.js": "^5.1.1"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tsconfig/svelte": "^5.0.5",
    "@types/node": "^26.1.0",
    "playwright": "^1.61.0",
    "sharp": "^0.33.5",
    "svelte": "^5.46.4",
    "svelte-check": "^4.3.5",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vite-plugin-pwa": "^1.0.3"
  }
}
