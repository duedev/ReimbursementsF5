# All optional — the app runs fully local with none of these set.

# --- Optional cloud sync (see SUPABASE_SETUP.md) ---------------------------
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...

# --- Optional "Save to OneDrive" (see ONEDRIVE_SETUP.md) --------------------
# Application (client) ID of a free Azure app registration whose redirect URI
# is registered as a Single-page application. Without it, every OneDrive
# surface stays hidden.
# VITE_ONEDRIVE_CLIENT_ID=00000000-0000-0000-0000-000000000000
# Pin sign-in to one Entra tenant (default "common" = personal + work/school):
# VITE_ONEDRIVE_TENANT=common
# Override the computed redirect URI (rarely needed):
# VITE_ONEDRIVE_REDIRECT_URI=https://your-registered-url.example/

# Optional: cookieless visit counting (Cloudflare Web Analytics). Create a
# site in the Cloudflare dashboard (Analytics & Logs -> Web Analytics), copy
# the token from its JS snippet, and set it here (or as a GitHub repo
# Variable for the Pages deploy). Page views only; without a token the build
# makes zero third-party requests.
# VITE_CF_ANALYTICS_TOKEN=your-token

# --- Optional zero-click free AI assist ------------------------------------
# Baked into the bundle at build time (never committed). Enables the OpenRouter
# free vision tier for anonymous users.
# OPENROUTER_API_KEY=sk-or-...

# --- OCR engine tier --------------------------------------------------------
# Default is Tesseract (vendored from npm, fully offline). Opt into the
# stronger on-device PaddleOCR tier after `npm i onnxruntime-web && npm run vendor:paddle`:
# VITE_OCR_ENGINE=paddle

# Serve Tesseract language data from the public CDN instead of vendoring:
# VITE_TESSDATA_LOCAL=0

# --- Perspective correction (angled phone photos) ---------------------------
# Requires a vendored OpenCV.js at public/vendor/opencv/opencv.js.
# VITE_PERSPECTIVE=1
